# ─────────────────────────────────────────
# Morning Briefing — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── News Source ───────────────────────────
NEWS_API_KEY=your_newsapi_key_here
# Get free key at https://newsapi.org

# ── LLM Provider (pick one) ───────────────
# Options: "openai" | "gemini" | "ollama"
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# Ollama — local open-source models (https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── TTS Provider ──────────────────────────
# Options: "openai" | "google" | "none" (script-only mode)
TTS_PROVIDER=openai
TTS_VOICE=coral
# OpenAI voices: alloy, echo, fable, onyx, nova, shimmer, coral
TTS_SPEED=0.9

# ── Supabase ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Storage ───────────────────────────────
# Options: "supabase" | "local"
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=briefing-audio
LOCAL_STORAGE_PATH=./output

# ── Email Delivery ────────────────────────
# Options: "smtp" | "none"
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_TO=recipient@example.com
EMAIL_FROM=your_email@gmail.com

# ── Briefing Content ─────────────────────
NEWS_COUNTRY=us
# Comma-separated: business,entertainment,general,health,science,sports,technology
NEWS_CATEGORIES=general,technology
NEWS_PAGE_SIZE=3
BRIEFING_LANGUAGE=English
# Target spoken duration in seconds (used in the LLM prompt)
BRIEFING_TARGET_SECONDS=60

# ── Phase 2 추가 설정 ─────────────────────────────────────────────────────
# Supabase Anon Key (대시보드 클라이언트 인증용 - 공개 가능)
SUPABASE_ANON_KEY=your_anon_public_key_here

# 관리자 이메일 (콤마로 구분, /api/admin/* 접근 권한)
ADMIN_EMAILS=your@email.com

# 수동 트리거 보안 키 (선택)
RUN_SECRET=some_random_secret
